# Copy to `.env.development`, `.env.preview`, or `.env.production` as needed.
# Values are loaded by `tools/load-radartips-env.mjs` (optional files; fail-closed defaults apply).

# development | preview | production
APP_ENV=development

# Public site origin (no trailing slash)
PUBLIC_SITE_URL=http://127.0.0.1:5173

# API base for client-side fetches in docs/tools (worker lives at /api/v1 on production)
PUBLIC_API_BASE_URL=http://127.0.0.1:8787/api/v1

# source = repo root HTML/assets | dist = built output
PUBLIC_PAGES_MODE=source

# 1 only for dist preview (also sets RADARTIPS_ALLOW_DIST_ROOT in loader)
ALLOW_DIST_ROOT=0

# fail-closed verify in CI/build (reserved; build is strict by default)
STRICT_VERIFY=1

# --- API-Football (tools/preview-pipeline-brasileirao.mjs, update-data-api-football.mjs, etc.) ---
# Put the real key in `.env.local`, `.env.preview.local`, or `.env.development.local` (gitignored).
# APIFOOTBALL_KEY=your_key_here
# API_FOOTBALL_KEY=your_key_here

# static | worker — how data is expected to be loaded locally
DATA_MODE=static

# Logical namespace for snapshots (see RADARTIPS_SNAPSHOT_PREFIX for R2)
SNAPSHOT_NAMESPACE=development

# R2 key prefix: prod | preview (required for upload-calendar-to-r2.mjs)
RADARTIPS_SNAPSHOT_PREFIX=prod

# Worker deployment label (documentation)
WORKER_ENV=development

# Cloudflare Pages label (documentation)
PAGES_ENV=development

# --- Local Cloudflare CLI / npm run pages:deploy (DO NOT commit real values) ---
# Put these in .env.production.local (gitignored), not in .env.production.
# CLOUDFLARE_API_TOKEN=...          # or CF_API_TOKEN
# CLOUDFLARE_ACCOUNT_ID=...        # or CF_ACCOUNT_ID
# CLOUDFLARE_PAGES_PROJECT_NAME=... # Pages slug; or RADARTIPS_PAGES_PROJECT_NAME
#
# R2 uploads (node upload-calendar-to-r2.mjs): the SAME token must include R2, not only Pages.
# Add permission: Account → Workers R2 Storage → Edit (bucket: radartips-data or all buckets).
# A Pages-only token returns HTTP 403 on r2 object put / r2 bucket list.
# R2_BUCKET_NAME=radartips-data     # optional; default matches Worker + CI
#
# GitHub Actions: same token + account id as repository Secrets; optional repo Variable RADARTIPS_PAGES_PROJECT_NAME for deploy_pages.yml when input is empty.
