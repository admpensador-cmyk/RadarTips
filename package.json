    "dev:ui": "node tools/dev-ui-session.mjs",
    "dev:ui:open": "node tools/dev-ui-session.mjs --open",
    "build": "node tools/build-static.mjs",
    "verify": "node tools/verify-no-zombie-radar.mjs"
  }
}
